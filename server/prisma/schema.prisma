// Prisma Schema for Paper to PPT Generator
// Database: SQLite (for development)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Plans table - subscription tiers
// PlanType: FREE, PAID, PREMIUM (stored as String for SQLite)
model Plan {
  id        String   @id @default(uuid())
  name      String   @unique
  price     Float    @default(0)
  features  String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  users     User[]

  @@map("plans")
}

// Users table - authentication and profile
// UserRole: USER, ADMIN (stored as String for SQLite)
model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String        @map("password_hash")
  name         String?
  role         String        @default("USER")
  planId       String?       @map("plan_id")
  plan         Plan?         @relation(fields: [planId], references: [id])
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  history      UserHistory[]
  ppts         Ppt[]

  @@map("users")
}

// User History - tracks paper conversions
model UserHistory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  paperName String   @map("paper_name")
  pptId     String?  @map("ppt_id")
  ppt       Ppt?     @relation(fields: [pptId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("user_history")
}

// PPT table - stores generated presentations
// slideJson stored as String (JSON stringified) for SQLite
model Ppt {
  id         String        @id @default(uuid())
  userId     String        @map("user_id")
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId String?       @map("template_id")
  title      String
  slideJson  String        @map("slide_json")
  pdfPath    String?       @map("pdf_path")
  texPath    String?       @map("tex_path")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  history    UserHistory[]

  @@map("ppts")
}
